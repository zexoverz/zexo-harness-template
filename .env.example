# =========================================
# zexo-harness-template .env.example
# Copy to .env and fill in real values.
# NEVER commit .env — it's gitignored.
# =========================================

# --- LLM ---
ANTHROPIC_API_KEY=sk-ant-...
# Optional fallback
OPENAI_API_KEY=

# --- MCP servers ---
# GitHub PAT with repo + read:org scopes
GITHUB_TOKEN=ghp_...

# --- Optional: deploy target ---
# Uncomment + fill for your cloud of choice. /deploy skill picks up whichever is set.

# GCP Cloud Run
# GCP_PROJECT_ID=
# GCP_REGION=asia-southeast2

# Vercel
# VERCEL_TOKEN=

# Fly.io
# FLY_API_TOKEN=

# --- Notification hook (optional) ---
# Slack incoming webhook URL — posts when a background agent finishes
# SLACK_WEBHOOK_URL=

# --- App runtime ---
NODE_ENV=development
PORT=8080
LOG_LEVEL=info

# --- Cost ceiling (optional) ---
# If your agent runtime supports it, auto-close sessions past this cost.
# COST_CEILING_SESSION_CENTS=50
