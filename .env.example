# =========================================
# foru-harness-template .env.example
# Copy to .env and fill in real values.
# NEVER commit .env — it's gitignored.
# =========================================

# --- LLM ---
ANTHROPIC_API_KEY=sk-ant-...
# Optional fallback
OPENAI_API_KEY=

# --- Chat channels (Coinfest demo) ---
# WhatsApp Cloud API (Meta)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=

# Telegram Bot API
TELEGRAM_BOT_TOKEN=

# --- Voice (optional / stretch) ---
# ElevenLabs (or swap for OpenAI Realtime)
ELEVENLABS_API_KEY=

# --- MCP servers ---
GITHUB_TOKEN=ghp_...

# --- Deploy target (GCP Cloud Run) ---
# Set these once via `gcloud auth application-default login` locally;
# in CI use a Workload Identity Provider — never paste service-account JSON here.
GCP_PROJECT_ID=
GCP_REGION=asia-southeast2

# --- App runtime ---
NODE_ENV=development
PORT=8080
LOG_LEVEL=info
